{
  "name": "docudevs-ai",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "sync-openapi-spec": "mkdir -p static/files && cp ../docudevs.yaml static/files/docudevs.yaml",
    "start": "npm run sync-openapi-spec && docusaurus start",
    "build": "npm run sync-openapi-spec && docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "npm run sync-openapi-spec && docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "gen-api-docs": "npm run sync-openapi-spec && docusaurus gen-api-docs all",
    "clean-api-docs": "docusaurus clean-api-docs all",
    "typecheck": "tsc",
    "api-docs": "npm run sync-openapi-spec && docusaurus clean-api-docs all && docusaurus gen-api-docs all"
  },
  "dependencies": {
    "@docusaurus/core": "3.8.1",
    "@docusaurus/preset-classic": "3.8.1",
    "@easyops-cn/docusaurus-search-local": "^0.55.0",
    "@mdx-js/react": "^3.0.0",
    "@reduxjs/toolkit": "^2.6.0",
    "clsx": "^2.0.0",
    "docusaurus-plugin-openapi-docs": "4.5.1",
    "docusaurus-theme-openapi-docs": "4.5.1",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.7.0",
    "@docusaurus/tsconfig": "3.7.0",
    "@docusaurus/types": "3.7.0",
    "typescript": "~5.6.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0"
  }
}
